# Ordivon Environment Configuration
# Copy to .env and fill in real values. .env is gitignored.

# ── Database ─────────────────────────────────────────────────────
# PostgreSQL (primary). Omit to fall back to SQLite.
ORDIVON_DB_URL=postgresql://ordivon:your_password@localhost:5432/ordivon
# SQLite fallback path (used when ORDIVON_DB_URL is empty)
# ORDIVON_SQLITE_PATH=./data/ordivon.sqlite

# ── NATS JetStream ───────────────────────────────────────────────
ORDIVON_NATS_URL=nats://localhost:4222

# ── Temporal ─────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=ordivon
TEMPORAL_TASK_QUEUE=ordivon-governance

# ── OpenFGA ──────────────────────────────────────────────────────
OPENFGA_API_URL=http://localhost:8081
OPENFGA_STORE_ID=ordivon

# ── Observability ────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=ordivon-governance
