{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm build:web && pnpm --dir apps/web exec next start --hostname 127.0.0.1 --port 3000",
      "startServerReadyPattern": "Ready",
      "url": [
        "http://127.0.0.1:3000/",
        "http://127.0.0.1:3000/analyze",
        "http://127.0.0.1:3000/reviews"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.5
          }
        ],
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.8
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.8
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
