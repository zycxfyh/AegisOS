{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Debt Lifecycle State Machine",
  "description": "Managed lifecycle for governance debts. OPEN → TRIAGED → MITIGATED → CLOSED. CLOSED requires close_evidence. Stale debts must be flagged.",
  "version": "0.1.0",
  "states": ["OPEN", "TRIAGED", "MITIGATED", "CLOSED", "DEFERRED", "EXPIRED", "SUPERSEDED", "REOPENED"],
  "required_fields": ["debt_id", "owner", "status", "severity", "opened_at", "review_trigger", "stale_after"],
  "state_rules": {
    "CLOSED": {"requires": ["close_evidence", "resolution"], "forbidden": []},
    "MITIGATED": {"requires": ["mitigation_evidence"], "forbidden": []},
    "SUPERSEDED": {"requires": ["superseded_by"], "forbidden": []},
    "REOPENED": {"requires": ["reopen_reason"], "forbidden": []},
    "EXPIRED": {"requires": ["expiry_reason"], "forbidden": []},
    "DEFERRED": {"requires": ["defer_reason", "defer_until"], "forbidden": []}
  },
  "blocking_conditions": [
    "CLOSED without close_evidence → BLOCKED",
    "OPEN past stale_after without review → DEGRADED",
    "SUPERSEDED without superseded_by → BLOCKED",
    "debt without owner → BLOCKED",
    "debt without review_trigger → BLOCKED"
  ],
  "transitions": [
    {"from": "OPEN", "to": "TRIAGED", "requires": "triage_receipt"},
    {"from": "TRIAGED", "to": "MITIGATED", "requires": "mitigation_receipt"},
    {"from": "MITIGATED", "to": "CLOSED", "requires": "close_evidence"},
    {"from": "OPEN", "to": "DEFERRED", "requires": "defer_reason + defer_until"},
    {"from": "DEFERRED", "to": "OPEN", "requires": "reopen_reason"},
    {"from": "OPEN", "to": "EXPIRED", "requires": "expiry_reason"},
    {"from": "CLOSED", "to": "REOPENED", "requires": "reopen_reason + new_evidence"}
  ]
}
