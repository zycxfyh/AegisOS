{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ordivon Authority Taxonomy",
  "description": "Domain-aware authority taxonomy replacing the overloaded flat 'source_of_truth' semantics. Authority is now three-dimensional: domain (what kind of truth), role (what authority level within domain), scope (what governed object). Designed from PM-2S RPR-4 findings (L-CI-SELFCAL-002 pattern).",
  "generated_at": "2026-05-11",
  "governed_by": "authority-taxonomy checker (GOS-PM-3)",
  "version": "0.1.0",
  "status": "proposed",
  "lesson_refs": ["L-CI-SELFCAL-002", "RPR-4-PM-2S"],
  "core_invariants": [
    "Authority ≠ Execution",
    "Owner ≠ Approver",
    "Implementation Source ≠ Documentation Source of Truth",
    "Schema Source ≠ Documentation Source of Truth",
    "Generated View ≠ Any Source",
    "Authority Upgrade Requires Evidence",
    "Cross-Domain Authority Transfer Requires Migration Receipt"
  ],
  "domains": {
    "documentation": {
      "description": "Document-level truth, current status, historical records, supporting evidence",
      "roles": ["doc_source_of_truth", "current_status", "supporting_evidence", "historical_record"],
      "route_match": ["governance-core", "ai-boundaries", "product-docs"],
      "risk": "governance"
    },
    "implementation": {
      "description": "Code implementation source, runtime logic, checker source",
      "roles": ["implementation_source", "runtime_logic", "checker_source"],
      "route_match": ["source-code", "governance-core"],
      "risk": "architecture_breach"
    },
    "schema": {
      "description": "Schema definition source, validation source",
      "roles": ["schema_source", "validation_source"],
      "route_match": ["config-and-schemas", "source-code"],
      "risk": "schema_drift"
    },
    "generated": {
      "description": "Derived views, generated observations — must never be source_of_truth",
      "roles": ["generated_view", "derived_observation"],
      "route_match": ["generated-views"],
      "risk": "drift"
    },
    "evidence": {
      "description": "Raw output, receipts, stage evidence, attestation records",
      "roles": ["raw_evidence", "evidence_record", "receipt"],
      "route_match": ["knowledge-assets", "governance-core"],
      "risk": "evidence_chain_break"
    },
    "policy": {
      "description": "Active policy, candidate policy, retired policy",
      "roles": ["active_policy", "candidate_policy", "retired_policy"],
      "route_match": ["governance-core"],
      "risk": "policy_overreach"
    },
    "runtime": {
      "description": "Runtime observation, CI output, tool execution trace",
      "roles": ["runtime_observation", "ci_receipt", "tool_trace"],
      "route_match": ["source-code", "knowledge-assets"],
      "risk": "observation_bias"
    },
    "external": {
      "description": "External reference, benchmark, third-party source",
      "roles": ["external_reference", "benchmark_reference"],
      "route_match": [],
      "risk": "external_authority_confusion"
    }
  },
  "compatibility_rules": {
    "generated_view_cannot_be": ["doc_source_of_truth", "current_status", "implementation_source", "schema_source"],
    "implementation_source_only_for": ["source-code", "governance-core"],
    "schema_source_only_for": ["config-and-schemas", "source-code"],
    "doc_source_of_truth_only_for": ["governance-core", "ai-boundaries", "product-docs"],
    "active_policy_only_for": ["governance-core"]
  },
  "migration_from_flat_authority": {
    "source_of_truth_on_doc": "doc_source_of_truth (documentation domain)",
    "source_of_truth_on_code": "implementation_source (implementation domain)",
    "source_of_truth_on_schema": "schema_source (schema domain)",
    "current_status": "current_status (documentation domain, unchanged)",
    "supporting_evidence": "supporting_evidence (documentation domain, unchanged)",
    "historical_record": "historical_record (documentation domain, unchanged)",
    "proposal": "candidate_policy (policy domain)"
  }
}
