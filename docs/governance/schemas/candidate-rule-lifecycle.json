{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidateRule Lifecycle State Machine",
  "description": "Managed lifecycle for CandidateRules. DRAFT → REVIEW_PENDING → SHADOW → RED_TEAMED → ACTIVATION_CANDIDATE / REJECTED / RETIRED. CandidateRule ≠ Policy. ACTIVATION_CANDIDATE ≠ ActivePolicy.",
  "version": "0.1.0",
  "states": ["DRAFT", "REVIEW_PENDING", "SHADOW", "RED_TEAMED", "ACTIVATION_CANDIDATE", "REJECTED", "RETIRED"],
  "required_fields": ["candidate_rule_id", "source_lesson_refs", "owner", "scope", "risk_level", "retirement_condition", "activation_requirements"],
  "state_rules": {
    "SHADOW": {"requires": ["shadow_evidence_refs"], "forbidden": []},
    "RED_TEAMED": {"requires": ["red_team_refs"], "forbidden": []},
    "ACTIVATION_CANDIDATE": {"requires": ["activation_requirements", "stage_summit_ref"], "forbidden": ["active_policy", "policy", "enforced"]}
  },
  "core_invariant": "CandidateRule ≠ Policy. ACTIVATION_CANDIDATE ≠ ActivePolicy. CandidateRule cannot be marked active_policy.",
  "blocking_conditions": [
    "CandidateRule marked active_policy → BLOCKED",
    "SHADOW without shadow_evidence → BLOCKED",
    "RED_TEAMED without red_team_refs → BLOCKED",
    "ACTIVATION_CANDIDATE without activation_requirements → BLOCKED"
  ],
  "transitions": [
    {"from": "DRAFT", "to": "REVIEW_PENDING", "requires": "draft_complete"},
    {"from": "REVIEW_PENDING", "to": "SHADOW", "requires": "shadow_receipt"},
    {"from": "SHADOW", "to": "RED_TEAMED", "requires": "red_team_receipt"},
    {"from": "RED_TEAMED", "to": "ACTIVATION_CANDIDATE", "requires": "activation_requirements_met"},
    {"from": "REVIEW_PENDING", "to": "REJECTED", "requires": "rejection_reason"},
    {"from": "RED_TEAMED", "to": "RETIRED", "requires": "retirement_reason"}
  ]
}
