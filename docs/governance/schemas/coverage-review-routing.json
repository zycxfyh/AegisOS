{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coverage Review Routing",
  "description": "Owner/reviewer/approver routing for coverage objects, batches, exclusions, and protected mutations. Owner ≠ Reviewer. Reviewer ≠ Approver. Owner Routing ≠ Authorization. Borrows from Kubernetes OWNERS (reviewer/approver separation) and GitHub CODEOWNERS (path-based routing).",
  "governed_by": "coverage-review-routing checker (GOS-PM-8)",
  "version": "0.1.0",
  "routing": {
    "governed": {
      "owner_source": "document-registry.jsonl (owner field)",
      "reviewer_route": "registry owner or delegate",
      "approver_route": "authority-gate reviewer",
      "mutation_requires_review": false,
      "authority_mutation_requires_approver": true
    },
    "generated": {
      "owner_source": "generator script + source_refs owner",
      "reviewer_route": "generator owner",
      "approver_route": "governance-core maintainer",
      "mutation_requires_review": false,
      "must_not_own_authority": true
    },
    "excluded": {
      "owner_source": "governed-exclusions.json (owner field)",
      "reviewer_route": "exclusion owner",
      "approver_route": "governance-core maintainer",
      "mutation_requires_review": true,
      "requires_removal_condition": true
    },
    "debt_parked": {
      "owner_source": "debt ledger (owner field)",
      "reviewer_route": "debt owner + governance reviewer",
      "approver_route": "governance-core maintainer if closing debt",
      "mutation_requires_review": true,
      "closing_requires_approver": true
    },
    "fixture": {
      "owner_source": "owning_test / checker CHECKER.md owner",
      "reviewer_route": "owning test maintainer",
      "approver_route": "checker owner if fixture affects gate behavior",
      "mutation_requires_review": false
    },
    "vendored": {
      "owner_source": "upstream source attribution",
      "reviewer_route": "governance reviewer for boundary",
      "approver_route": "governance-core maintainer",
      "mutation_requires_review": true
    },
    "external": {
      "owner_source": "external source reference",
      "reviewer_route": "governance reviewer for staleness",
      "approver_route": "governance-core maintainer",
      "mutation_requires_review": false
    },
    "legacy": {
      "owner_source": "legacy boundary declaration",
      "reviewer_route": "governance reviewer for routing decision",
      "approver_route": "governance-core maintainer",
      "mutation_requires_review": true
    },
    "temporary": {
      "owner_source": "creator or expiry declaration",
      "reviewer_route": "creator review at expiry",
      "approver_route": "governance-core maintainer if extending",
      "mutation_requires_review": true,
      "expiry_enforced": true
    },
    "blocked": {
      "owner_source": "none — must be resolved immediately",
      "reviewer_route": "governance-core maintainer",
      "approver_route": "governance-core maintainer",
      "mutation_requires_review": true,
      "auto_enforced": true
    }
  },
  "mutation_review_rules": {
    "protected_path_change": {"review_required": true, "approver_required": true},
    "authority_domain_change": {"review_required": true, "approver_required": true},
    "authority_role_change": {"review_required": true, "approver_required": true},
    "exclusion_add": {"review_required": true, "approver_required": false},
    "exclusion_remove": {"review_required": true, "approver_required": true},
    "debt_park": {"review_required": true, "approver_required": false},
    "debt_close": {"review_required": true, "approver_required": true},
    "generated_source_refs_change": {"review_required": true, "approver_required": false}
  },
  "core_invariants": [
    "Owner ≠ Reviewer",
    "Reviewer ≠ Approver",
    "Owner ≠ Authority",
    "Review Route ≠ Approval",
    "Approval Route ≠ Execution",
    "Generated View Cannot Own Authority",
    "Owner Routing ≠ Authorization"
  ]
}
