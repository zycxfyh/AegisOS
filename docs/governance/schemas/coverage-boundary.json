{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ordivon Coverage Boundary",
  "description": "Coverage classification taxonomy for all git-tracked files. Every file must have an explicit coverage status. Unknown protected paths → BLOCKED. Excluded ≠ nonexistent. Debt-parked ≠ ignored. Generated ≠ source. Coverage boundary ≠ full closure.",
  "governed_by": "coverage-boundary checker (GOS-PM-5)",
  "version": "0.1.0",
  "status": "proposed",
  "coverage_statuses": [
    "governed",
    "generated",
    "excluded",
    "debt_parked",
    "fixture",
    "vendored",
    "external",
    "legacy",
    "temporary",
    "blocked"
  ],
  "status_definitions": {
    "governed": {
      "description": "Governed object — has registry entry, path-map node, route, authority domain/role",
      "required_metadata": [
        "registry_entry",
        "path_map_node",
        "route",
        "authority_domain",
        "authority_role"
      ]
    },
    "generated": {
      "description": "Derived/generated view — must have source_refs, must NOT be source_of_truth",
      "required_metadata": [
        "source_refs",
        "generated_from"
      ],
      "forbidden_authority": [
        "doc_source_of_truth",
        "implementation_source",
        "schema_source",
        "active_policy"
      ]
    },
    "excluded": {
      "description": "Explicitly excluded from governance — must have owner, reason, review_date, removal_condition",
      "required_metadata": [
        "owner",
        "reason",
        "review_date",
        "removal_condition"
      ]
    },
    "debt_parked": {
      "description": "Governance gap recorded as A4 debt — must have valid debt_id in debt ledger",
      "required_metadata": [
        "debt_id",
        "owner",
        "review_trigger",
        "removal_condition"
      ]
    },
    "fixture": {
      "description": "Test fixture / negative demo — must have owning test or checker",
      "required_metadata": [
        "owning_test",
        "scope",
        "negative_or_positive"
      ]
    },
    "vendored": {
      "description": "Third-party vendored code/content — must have upstream source and license boundary",
      "required_metadata": [
        "upstream_source",
        "license"
      ]
    },
    "external": {
      "description": "External reference material — must have source and staleness boundary",
      "required_metadata": [
        "external_source",
        "staleness_threshold"
      ]
    },
    "legacy": {
      "description": "Historical/legacy object — must have boundary and routing decision",
      "required_metadata": [
        "legacy_boundary",
        "routing_decision",
        "review_trigger"
      ]
    },
    "temporary": {
      "description": "Temporary/debug file — must have expiry, cannot persist indefinitely",
      "required_metadata": [
        "expiry",
        "purpose"
      ]
    },
    "blocked": {
      "description": "Protected path, unclassified — must be resolved (govern, exclude, generate, debt-park, fixture)",
      "required_metadata": [],
      "action": "BLOCKED"
    }
  },
  "protected_paths": [
    "docs/governance/**",
    "docs/ai/**",
    "docs/architecture/**",
    "docs/product/**",
    "checkers/**",
    "scripts/check_*",
    "scripts/update_*",
    "scripts/verify_*",
    "scripts/reconcile*",
    "scripts/hash_ledger*",
    "scripts/review_lessons*",
    "scripts/detect_overclaim*",
    "scripts/detect_agentic*",
    "scripts/collect-stage*",
    "scripts/verify-stage*",
    "scripts/generate-*",
    "scripts/triage*",
    "scripts/explain*",
    "scripts/run_baseline*",
    "scripts/run_stage*",
    ".github/workflows/**"
  ],
  "classification_rules": [
    {
      "id": "excluded-schemas-in-protected",
      "match": {
        "path_match": "docs/governance/schemas/*.json"
      },
      "coverage": "excluded",
      "source": "schema file in governed dir — excluded from doc governance"
    },
    {
      "id": "orchestration-scripts",
      "match": {
        "path_match": "scripts/run_*"
      },
      "coverage": "governed",
      "source": "orchestration script"
    },
    {
      "id": "governance-scripts",
      "match": {
        "path_match": "scripts/check_*"
      },
      "coverage": "governed",
      "source": "governance script"
    },
    {
      "id": "governed-by-registry",
      "match": {
        "has_registry_entry": true,
        "classification_status": "governed"
      },
      "coverage": "governed"
    },
    {
      "id": "generated-views",
      "match": {
        "kind": "generated_view"
      },
      "coverage": "generated"
    },
    {
      "id": "explicit-exclusions",
      "match": {
        "has_exclusion": true
      },
      "coverage": "excluded"
    },
    {
      "id": "code-sources",
      "match": {
        "route": "source-code"
      },
      "coverage": "governed"
    },
    {
      "id": "test-fixtures",
      "match": {
        "path_match": "tests/fixtures/**"
      },
      "coverage": "fixture"
    },
    {
      "id": "legacy-dirs",
      "match": {
        "path_match": "**/legacy/**"
      },
      "coverage": "legacy"
    },
    {
      "id": "archived-dirs",
      "match": {
        "path_match": "**/archive/**"
      },
      "coverage": "legacy"
    },
    {
      "id": "vendor-dirs",
      "match": {
        "path_match": "**/vendor/**"
      },
      "coverage": "vendored"
    },
    {
      "id": "debt-parked",
      "match": {
        "has_debt_id": true
      },
      "coverage": "debt_parked"
    },
    {
      "id": "non-protected-source",
      "match": {
        "path_match": "src/**"
      },
      "coverage": "governed",
      "source": "source directory"
    }
  ],
  "fallbacks": [
    {
      "condition": "protected_path_unknown",
      "action": "blocked",
      "remediation": "Add registry entry, explicit exclusion with owner/reason, generated source_refs, or A4 debt"
    },
    {
      "condition": "non_protected_unknown",
      "action": "debt_or_exclusion_required",
      "remediation": "Record as A4 debt or add explicit exclusion"
    }
  ]
}
