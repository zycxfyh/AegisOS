{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lesson Lifecycle State Machine",
  "description": "Managed lifecycle for governance lessons. RECORDED → REVIEW_PENDING → ACTIONED / REJECTED / CANDIDATE_RULE / STALE. ACTIONED requires action_refs.",
  "version": "0.1.0",
  "states": ["RECORDED", "REVIEW_PENDING", "ACTIONED", "REJECTED", "CANDIDATE_RULE", "STALE"],
  "required_fields": ["lesson_id", "source_event", "owner", "review_trigger", "decision", "stale_after"],
  "state_rules": {
    "ACTIONED": {"requires": ["action_refs", "action_evidence"], "forbidden": []},
    "CANDIDATE_RULE": {"requires": ["candidate_rule_id"], "forbidden": []},
    "REJECTED": {"requires": ["rejection_reason"], "forbidden": []},
    "STALE": {"requires": ["stale_reason"], "forbidden": []}
  },
  "blocking_conditions": [
    "ACTIONED without action_refs → BLOCKED",
    "CANDIDATE_RULE without candidate_rule_id → BLOCKED",
    "REVIEW_PENDING past stale_after → DEGRADED",
    "lesson without owner → BLOCKED"
  ],
  "transitions": [
    {"from": "RECORDED", "to": "REVIEW_PENDING", "requires": "review_assignment"},
    {"from": "REVIEW_PENDING", "to": "ACTIONED", "requires": "action_refs + evidence"},
    {"from": "REVIEW_PENDING", "to": "REJECTED", "requires": "rejection_reason"},
    {"from": "REVIEW_PENDING", "to": "CANDIDATE_RULE", "requires": "candidate_rule_id"},
    {"from": "REVIEW_PENDING", "to": "STALE", "requires": "stale_reason"}
  ]
}
