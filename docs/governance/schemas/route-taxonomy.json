{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ordivon Route Taxonomy",
  "description": "Route taxonomy replacing simple string-based route labels. Each route has a domain, class, layer, scope, match strategy, allowed/forbidden doc_types, expected authority domains, and expected checkers. Routes are governance topology, not navigation. doc_type ≠ route.",
  "governed_by": "route-taxonomy checker (GOS-PM-4)",
  "version": "0.1.0",
  "status": "proposed",
  "lesson_refs": [
    "RPR-3-PM-3"
  ],
  "routes": {
    "governance-core": {
      "label": "Governance Core",
      "route_domain": "governance",
      "route_class": "core",
      "route_layer": "L1",
      "route_scope": "methodology-control-plane",
      "match": {
        "paths": [
          "docs/governance/**",
          "checkers/**",
          "scripts/*governance*",
          "scripts/check_*",
          "scripts/verify_*",
          "scripts/update_*",
          "scripts/reconcile*",
          "scripts/triage*",
          "scripts/hash_ledger*",
          "scripts/review_lessons*",
          "scripts/detect_overclaim*",
          "scripts/detect_agentic*",
          "scripts/collect-stage*",
          "scripts/verify-stage*",
          "scripts/generate-reconciliation*",
          "scripts/generate-path-map*",
          "scripts/explain*",
          ".github/workflows/**",
          "AGENTS.md"
        ],
        "doc_types": [
          "governance_pack",
          "methodology",
          "template",
          "checker",
          "tooling",
          "proposal",
          "receipt",
          "ledger",
          "root_context",
          "schema",
          "architecture",
          "design_spec",
          "supporting_evidence",
          "inventory",
          "triage",
          "boundary",
          "red_team",
          "tracker",
          "runbook"
        ]
      },
      "allowed_doc_types": [
        "governance_pack",
        "methodology",
        "template",
        "checker",
        "tooling",
        "proposal",
        "receipt",
        "ledger",
        "root_context",
        "schema",
        "architecture",
        "design_spec",
        "supporting_evidence",
        "inventory",
        "triage",
        "boundary",
        "red_team",
        "tracker",
        "runbook"
      ],
      "expected_authority_domains": [
        "documentation",
        "schema",
        "implementation",
        "policy"
      ],
      "expected_checkers": [
        "document-registry",
        "authority-gate",
        "path-map",
        "registry-path-reconciliation"
      ],
      "mismatch_disposition": "A2",
      "priority": 10
    },
    "ai-boundaries": {
      "label": "AI Boundaries",
      "route_domain": "ai",
      "route_class": "boundary",
      "route_layer": "L2",
      "route_scope": "ai-onboarding-runtime",
      "match": {
        "paths": [
          "docs/ai/**",
          "docs/runtime/**",
          "docs/runbooks/**"
        ],
        "doc_types": [
          "ai_onboarding",
          "phase_boundary",
          "runtime",
          "boundary",
          "context",
          "supporting_evidence",
          "architecture",
          "design_spec",
          "current-system-map",
          "knowledge-map",
          "reading-graph",
          "template",
          "tooling",
          "receipt",
          "runbook",
          "schema",
          "ledger",
          "tracker"
        ]
      },
      "allowed_doc_types": [
        "ai_onboarding",
        "phase_boundary",
        "runtime",
        "boundary",
        "context",
        "supporting_evidence",
        "architecture",
        "design_spec",
        "current-system-map",
        "knowledge-map",
        "reading-graph",
        "template",
        "tooling",
        "receipt",
        "runbook",
        "schema",
        "ledger",
        "tracker"
      ],
      "expected_authority_domains": [
        "documentation"
      ],
      "expected_checkers": [
        "document-registry",
        "authority-gate"
      ],
      "mismatch_disposition": "A2",
      "priority": 8
    },
    "product-docs": {
      "label": "Product Documentation",
      "route_domain": "product",
      "route_class": "docs",
      "route_layer": "L2",
      "route_scope": "product-specs-architecture",
      "match": {
        "paths": [
          "docs/product/**",
          "docs/architecture/**"
        ],
        "doc_types": [
          "product",
          "architecture",
          "design_spec",
          "stage_summit",
          "proposal",
          "receipt",
          "runbook",
          "schema"
        ]
      },
      "allowed_doc_types": [
        "product",
        "architecture",
        "design_spec",
        "stage_summit",
        "proposal",
        "receipt",
        "runbook",
        "schema"
      ],
      "expected_authority_domains": [
        "documentation"
      ],
      "expected_checkers": [
        "document-registry"
      ],
      "mismatch_disposition": "A2",
      "priority": 7
    },
    "generated-views": {
      "label": "Generated Views",
      "route_domain": "generated",
      "route_class": "derived",
      "route_layer": "L0",
      "route_scope": "auto-generated-outputs",
      "match": {
        "paths": [
          "docs/**/generated/**",
          "docs/**/_*.md"
        ],
        "doc_types": []
      },
      "allowed_doc_types": [],
      "forbidden_doc_types": [
        "doc_source_of_truth",
        "current_status",
        "implementation_source",
        "schema_source",
        "active_policy"
      ],
      "expected_authority_domains": [
        "generated"
      ],
      "must_not_be_source_of_truth": true,
      "mismatch_disposition": "A1_OR_A2",
      "priority": 5
    },
    "knowledge-assets": {
      "label": "Knowledge Assets",
      "route_domain": "knowledge",
      "route_class": "ledger",
      "route_layer": "L3",
      "route_scope": "lessons-debts-candidate-rules",
      "match": {
        "paths": [
          "docs/governance/lesson-ledger*",
          "docs/governance/dependency-audit-debts*",
          "docs/governance/candidate-rule-drafts*",
          "docs/governance/lesson-extraction*",
          "docs/governance/verification-debt*"
        ],
        "doc_types": [
          "ledger",
          "lesson"
        ]
      },
      "allowed_doc_types": [
        "ledger",
        "lesson"
      ],
      "expected_authority_domains": [
        "evidence"
      ],
      "expected_checkers": [
        "hash-ledger"
      ],
      "mismatch_disposition": "A4",
      "priority": 6
    },
    "config-and-schemas": {
      "label": "Configuration & Schemas",
      "route_domain": "schema",
      "route_class": "definition",
      "route_layer": "L2",
      "route_scope": "governance-schemas",
      "match": {
        "paths": [
          "docs/governance/schemas/*.json"
        ],
        "doc_types": [
          "schema"
        ]
      },
      "allowed_doc_types": [
        "schema"
      ],
      "expected_authority_domains": [
        "schema"
      ],
      "expected_checkers": [
        "governance-self-check"
      ],
      "mismatch_disposition": "A2",
      "priority": 9
    },
    "source-code": {
      "label": "Source Code",
      "route_domain": "code",
      "route_class": "implementation",
      "route_layer": "L0",
      "route_scope": "all-implementation-code",
      "match": {
        "paths": [
          "src/**",
          "governance_engine/**",
          "state/**",
          "domains/**",
          "capabilities/**",
          "execution/**",
          "shared/**",
          "packs/**",
          "adapters/**",
          "scripts/run_*"
        ],
        "doc_types": []
      },
      "allowed_doc_types": [],
      "expected_authority_domains": [
        "implementation",
        "schema",
        "runtime"
      ],
      "expected_checkers": [
        "architecture-boundaries"
      ],
      "mismatch_disposition": "A1",
      "priority": 1
    }
  },
  "fallbacks": [
    {
      "condition": "protected_path_unmatched",
      "action": "BLOCKED"
    },
    {
      "condition": "non_protected_unmatched",
      "action": "DEBT_OR_EXCLUSION_REQUIRED"
    }
  ]
}
