digraph PM_Scenarios {
  rankdir="TB";
  node [shape=box,style=filled,fontname="JetBrains Mono",fontsize=11];
  edge [fontsize=9];

  // === SCENARIO 1 ===
  subgraph cluster_s1 {
    label="SCENARIO 1: 新文件未注册";
    style=filled; fillcolor="#1e293b20"; color="#a78bfa"; fontsize=14;

    s1_push [label="git push\ndocs/governance/new-policy.md",fillcolor="#a78bfa20",color="#a78bfa"];
    s1_atomic [label="atomic-governance\ngate",fillcolor="#a78bfa20",color="#a78bfa"];
    s1_pathmap [label="verify-path-map",fillcolor="#a78bfa20",color="#a78bfa"];
    s1_block [label="BLOCKED\n未注册 · 无路由",fillcolor="#fb718520",color="#fb7185",shape=octagon];
    s1_fix [label="开发者:\n添加 registry 条目\n+ doc_type + owner",fillcolor="#34d39920",color="#34d399"];
    s1_pass [label="READY\nPASS",fillcolor="#34d39920",color="#34d399"];

    s1_push -> s1_atomic;
    s1_push -> s1_pathmap;
    s1_atomic -> s1_block;
    s1_pathmap -> s1_block;
    s1_block -> s1_fix;
    s1_fix -> s1_pass;
  }

  // === SCENARIO 2 ===
  subgraph cluster_s2 {
    label="SCENARIO 2: 静默修改债务状态";
    style=filled; fillcolor="#1e293b20"; color="#34d399"; fontsize=14;

    s2_edit [label="某人:\nOPEN → CLOSED\n'resolved by system update'",fillcolor="#34d39920",color="#34d399"];
    s2_hash [label="hash_ledger\n--verify",fillcolor="#34d39920",color="#34d399"];
    s2_block [label="BLOCKED\nHASH MISMATCH",fillcolor="#fb718520",color="#fb7185",shape=octagon];
    s2_rec [label="reconciler:\n无 receipt 证据",fillcolor="#fbbf24",color="#fbbf24"];
    s2_fix [label="正确路径:\n1. 提供 receipt 证据\n2. 重新计算 hash\n3. 走 review route",fillcolor="#34d399",color="#34d399"];

    s2_edit -> s2_hash;
    s2_hash -> s2_block;
    s2_block -> s2_rec;
    s2_rec -> s2_fix;
  }

  // === SCENARIO 3 ===
  subgraph cluster_s3 {
    label="SCENARIO 3: AI 声称系统完成";
    style=filled; fillcolor="#1e293b20"; color="#fbbf24"; fontsize=14;

    s3_ai [label="AI:\n'系统已全部完成\n全绿'",fillcolor="#fbbf24",color="#fbbf24"];
    s3_detect [label="detect_overclaim.py\ncontrolled vocabulary",fillcolor="#fbbf24",color="#fbbf24"];
    s3_block [label="BLOCKED\nOC-1: '完成' 禁用\nOC-1: '全绿' 禁用",fillcolor="#fb718520",color="#fb7185",shape=octagon];
    s3_fix [label="AI 被迫改成:\n'PM-1 VERIFIED,\n826 CB-12 OPEN,\nFull Closure: NOT CLAIMED'",fillcolor="#34d399",color="#34d399"];
    s3_pass [label="PASS",fillcolor="#34d39920",color="#34d399"];

    s3_ai -> s3_detect;
    s3_detect -> s3_block;
    s3_block -> s3_fix;
    s3_fix -> s3_pass;
  }
}
