{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/intent.schema.json",
  "title": "Ordivon Intent",
  "type": "object",
  "required": ["intentId", "requester", "scope", "riskTier", "traceId", "createdAt"],
  "properties": {
    "intentId": {"type": "string", "minLength": 1},
    "requester": {"type": "string", "minLength": 1},
    "scope": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "riskTier": {"type": "string", "enum": ["R0", "R1", "R2", "R3", "R4", "R5"]},
    "traceId": {"type": "string", "minLength": 1},
    "createdAt": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
