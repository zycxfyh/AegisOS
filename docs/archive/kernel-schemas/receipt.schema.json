{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/receipt.schema.json",
  "title": "Ordivon Receipt",
  "type": "object",
  "required": [
    "receiptId",
    "intentId",
    "obligationId",
    "verdict",
    "observedEventRefs",
    "stateTransitions",
    "debtRefs",
    "issuedBy",
    "issuedAt",
    "comparatorDigest"
  ],
  "properties": {
    "receiptId": {"type": "string", "minLength": 1},
    "intentId": {"type": "string", "minLength": 1},
    "obligationId": {"type": "string", "minLength": 1},
    "verdict": {
      "type": "string",
      "enum": ["ExactMatch", "Under", "Over", "Mis", "Unverifiable", "DeclarationInvalid", "SystemError"]
    },
    "observedEventRefs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "stateTransitions": {"type": "array", "items": {"type": "string"}},
    "debtRefs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "issuedBy": {"type": "string", "minLength": 1},
    "issuedAt": {"type": "string", "format": "date-time"},
    "comparatorDigest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "supersedesReceipt": {"type": "string"}
  },
  "additionalProperties": false
}
