{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/projection-manifest.schema.json",
  "title": "Ordivon Projection Manifest",
  "description": "Projection is rebuildable view metadata, not canonical truth.",
  "type": "object",
  "required": ["projectionId", "sourceFirstSeq", "sourceLastSeq", "eventCount", "headHash", "rebuiltAt"],
  "properties": {
    "projectionId": {"type": "string", "minLength": 1},
    "sourceFirstSeq": {"type": "integer", "minimum": 1},
    "sourceLastSeq": {"type": "integer", "minimum": 1},
    "eventCount": {"type": "integer", "minimum": 1},
    "headHash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "rebuiltAt": {"type": "string", "format": "date-time"},
    "rebuildCommand": {"type": "string"}
  },
  "additionalProperties": false
}
