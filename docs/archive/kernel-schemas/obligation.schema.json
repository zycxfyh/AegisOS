{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/obligation.schema.json",
  "title": "Ordivon Obligation",
  "type": "object",
  "required": ["obligationId", "intentId", "declaredActions", "declarationHash", "expiresAt"],
  "properties": {
    "obligationId": {"type": "string", "minLength": 1},
    "intentId": {"type": "string", "minLength": 1},
    "declaredActions": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "declarationHash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "expiresAt": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
