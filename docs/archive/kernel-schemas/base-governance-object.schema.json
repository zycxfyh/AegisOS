{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/base-governance-object.schema.json",
  "title": "Ordivon Base Governance Object",
  "type": "object",
  "required": [
    "id",
    "objectType",
    "schemaVersion",
    "origin",
    "createdAt",
    "createdBy",
    "provenance",
    "state",
    "digest",
    "signatureRefs",
    "retentionClass"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "objectType": {"type": "string", "minLength": 1},
    "schemaVersion": {"type": "string", "minLength": 1},
    "origin": {
      "type": "string",
      "enum": [
        "HUMAN_WRITTEN",
        "AI_WRITTEN",
        "SYSTEM_OBSERVED",
        "SYSTEM_DERIVED",
        "HUMAN_ATTESTED",
        "EXTERNAL_ATTESTED"
      ]
    },
    "createdAt": {"type": "string", "format": "date-time"},
    "createdBy": {"type": "string", "minLength": 1},
    "provenance": {
      "type": "object",
      "required": ["inputRefs", "collector", "digest"],
      "properties": {
        "inputRefs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "collector": {"type": "string", "minLength": 1},
        "digest": {"type": "string", "minLength": 8},
        "signatureRefs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      },
      "additionalProperties": false
    },
    "state": {"type": "string", "minLength": 1},
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "signatureRefs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "retentionClass": {"type": "string", "enum": ["ephemeral", "standard", "audit", "legal_hold"]}
  },
  "additionalProperties": true
}
