{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/policy-conflict.schema.json",
  "title": "Ordivon Policy Conflict Decision",
  "type": "object",
  "required": ["decisionId", "matchedPolicies", "outcome", "precedence"],
  "properties": {
    "decisionId": {"type": "string", "minLength": 1},
    "matchedPolicies": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "outcome": {"type": "string", "enum": ["Deny", "ConditionalAllow", "Preference"]},
    "precedence": {
      "type": "string",
      "enum": [
        "legal_regulatory_hard_deny",
        "security_hard_deny",
        "privacy_hard_deny",
        "legal_or_incident_hold",
        "contractual_consent_residency",
        "enterprise_governance",
        "domain_workflow",
        "operational_preference"
      ]
    },
    "reason": {"type": "string"}
  },
  "additionalProperties": false
}
