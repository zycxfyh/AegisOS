{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/candidate-policy.schema.json",
  "title": "Ordivon Candidate Policy",
  "type": "object",
  "required": ["candidatePolicyId", "scope", "ruleText", "evidenceRefs", "metricsGate", "status"],
  "properties": {
    "candidatePolicyId": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "minLength": 1},
    "ruleText": {"type": "string", "minLength": 1},
    "policyModule": {"type": "string"},
    "evidenceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "metricsGate": {"type": "object", "additionalProperties": true},
    "status": {"type": "string", "enum": ["Candidate", "Shadow", "Review", "LimitedRollout", "Rejected"]}
  },
  "additionalProperties": false
}
