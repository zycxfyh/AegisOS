{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/authority-token.schema.json",
  "title": "Ordivon Bound Authority Token",
  "type": "object",
  "required": [
    "jti",
    "kid",
    "iss",
    "sub",
    "audience",
    "intentId",
    "obligationId",
    "actionClass",
    "targetRef",
    "policyHash",
    "issuedAt",
    "notBefore",
    "expiresAt",
    "maxUseCount",
    "idempotencyKey",
    "sealRef",
    "signature"
  ],
  "properties": {
    "jti": {"type": "string", "minLength": 1},
    "kid": {"type": "string", "minLength": 1},
    "iss": {"type": "string", "minLength": 1},
    "sub": {"type": "string", "minLength": 1},
    "audience": {"type": "string", "minLength": 1},
    "intentId": {"type": "string", "minLength": 1},
    "obligationId": {"type": "string", "minLength": 1},
    "actionClass": {"type": "string", "minLength": 1},
    "targetRef": {"type": "string", "minLength": 1},
    "policyHash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "issuedAt": {"type": "string", "format": "date-time"},
    "notBefore": {"type": "string", "format": "date-time"},
    "expiresAt": {"type": "string", "format": "date-time"},
    "maxUseCount": {"type": "integer", "const": 1},
    "idempotencyKey": {"type": "string", "minLength": 1},
    "sealRef": {"type": "string", "minLength": 1},
    "signature": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
