{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/promotion.schema.json",
  "title": "Ordivon Policy Promotion",
  "type": "object",
  "required": [
    "promotionId",
    "candidatePolicyRef",
    "shadowPassed",
    "replayPassed",
    "reviewerAuthorityRefs",
    "rolloutPlan",
    "rollbackPlan"
  ],
  "properties": {
    "promotionId": {"type": "string", "minLength": 1},
    "candidatePolicyRef": {"type": "string", "minLength": 1},
    "shadowPassed": {"type": "boolean", "const": true},
    "replayPassed": {"type": "boolean", "const": true},
    "reviewerAuthorityRefs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "rolloutPlan": {"type": "string", "minLength": 1},
    "rollbackPlan": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
