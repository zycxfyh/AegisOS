{
  "servers": [
    {
      "id": "local-filesystem",
      "name": "Local Filesystem",
      "source": "built-in",
      "trust_level": "reviewed",
      "description": "Read/write project files within Ordivon repo boundary",
      "tools": {
        "read_file": {"permission": "M1", "approval_required": false},
        "write_file": {"permission": "M3", "approval_required": false, "receipt_required": true},
        "search_files": {"permission": "M1", "approval_required": false}
      },
      "scope": "/root/projects/Ordivon",
      "forbidden": ["delete outside scope", "modify .git"]
    },
    {
      "id": "local-postgres",
      "name": "Ordivon PostgreSQL",
      "source": "docker-compose",
      "trust_level": "reviewed",
      "description": "Ordivon governance database (PG 16 + pgvector)",
      "tools": {
        "query": {"permission": "M2", "approval_required": false},
        "migrate": {"permission": "M3", "approval_required": true, "receipt_required": true},
        "drop_table": {"permission": "M5", "approval_required": true, "receipt_required": true, "forbidden_by_default": true}
      },
      "connection": "postgresql://ordivon:ordivon@localhost:5432/ordivon",
      "audit_logging": false
    },
    {
      "id": "local-nats",
      "name": "NATS JetStream",
      "source": "docker-compose",
      "trust_level": "reviewed",
      "description": "Governance event bus",
      "tools": {
        "publish": {"permission": "M3", "approval_required": false, "receipt_required": false},
        "subscribe": {"permission": "M2", "approval_required": false}
      },
      "connection": "nats://localhost:4222"
    },
    {
      "id": "github-api",
      "name": "GitHub API",
      "source": "official",
      "trust_level": "reviewed",
      "description": "GitHub repository operations",
      "tools": {
        "read_issue": {"permission": "M2", "approval_required": false},
        "create_issue": {"permission": "M4", "approval_required": true, "receipt_required": true},
        "create_pr": {"permission": "M4", "approval_required": true, "receipt_required": true},
        "merge_pr": {"permission": "M5", "approval_required": true, "receipt_required": true, "forbidden_by_default": true}
      },
      "forbidden": ["delete_repository", "force_push", "modify_permissions"]
    }
  ],
  "default_policy": {
    "untrusted_servers": "deny_all",
    "m5_tools": "require_explicit_human_approval",
    "mutating_tools": "require_receipt"
  }
}
