# Auto-detect text files and normalize to LF
* text=auto

# Explicit LF enforcement for source code and config files
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sql text eol=lf
*.txt text eol=lf
*.env.example text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Binary files
*.duckdb binary
*.db binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.mp3 binary
*.wav binary
*.zip binary
*.tar.gz binary
