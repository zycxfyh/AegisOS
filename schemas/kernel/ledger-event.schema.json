{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/ledger-event.schema.json",
  "title": "Ordivon Append-only Ledger Event",
  "type": "object",
  "required": [
    "eventSeq",
    "eventId",
    "eventType",
    "origin",
    "createdAt",
    "objectType",
    "objectId",
    "payload",
    "payloadHash",
    "prevHash",
    "eventHash"
  ],
  "properties": {
    "eventSeq": {"type": "integer", "minimum": 1},
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"type": "string", "minLength": 1},
    "origin": {
      "type": "string",
      "enum": [
        "HUMAN_WRITTEN",
        "AI_WRITTEN",
        "SYSTEM_OBSERVED",
        "SYSTEM_DERIVED",
        "HUMAN_ATTESTED",
        "EXTERNAL_ATTESTED"
      ]
    },
    "createdAt": {"type": "string", "format": "date-time"},
    "objectType": {"type": "string", "minLength": 1},
    "objectId": {"type": "string", "minLength": 1},
    "payload": {"type": "object"},
    "payloadHash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "prevHash": {"type": "string", "minLength": 8},
    "eventHash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "segmentId": {"type": "string"},
    "signatureRefs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  },
  "additionalProperties": false
}
