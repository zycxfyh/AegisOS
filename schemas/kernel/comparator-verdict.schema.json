{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/comparator-verdict.schema.json",
  "title": "Ordivon Comparator Verdict",
  "type": "object",
  "required": ["verdict", "priority", "comparedRefs", "mismatchDetail"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["ExactMatch", "Under", "Over", "Mis", "Unverifiable", "DeclarationInvalid", "SystemError"]
    },
    "priority": {"type": "integer", "minimum": 10, "maximum": 70},
    "comparedRefs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "mismatchDetail": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
