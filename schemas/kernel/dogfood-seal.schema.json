{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/dogfood-seal.schema.json",
  "title": "Ordivon Dogfood Seal",
  "type": "object",
  "required": [
    "sealId",
    "scenarioCount",
    "criticalBypasses",
    "scenarioRefs",
    "receiptRefs",
    "issuedAt"
  ],
  "properties": {
    "sealId": {"type": "string", "minLength": 1},
    "scenarioCount": {"type": "integer", "minimum": 1},
    "criticalBypasses": {"type": "integer", "minimum": 0},
    "scenarioRefs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "receiptRefs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "issuedAt": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
