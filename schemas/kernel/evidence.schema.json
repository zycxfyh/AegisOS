{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/evidence.schema.json",
  "title": "Ordivon Evidence",
  "type": "object",
  "required": ["evidenceId", "sourceRef", "collector", "observedAt", "trustTier", "digest", "origin"],
  "properties": {
    "evidenceId": {"type": "string", "minLength": 1},
    "sourceRef": {"type": "string", "minLength": 1},
    "collector": {"type": "string", "minLength": 1},
    "observedAt": {"type": "string", "format": "date-time"},
    "validUntil": {"type": "string", "format": "date-time"},
    "trustTier": {"type": "string", "enum": ["T0", "T1", "T2", "T3", "T4", "T5"]},
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "origin": {
      "type": "string",
      "enum": ["HUMAN_WRITTEN", "AI_WRITTEN", "SYSTEM_OBSERVED", "SYSTEM_DERIVED", "HUMAN_ATTESTED", "EXTERNAL_ATTESTED"]
    },
    "independenceGroup": {"type": "string"}
  },
  "additionalProperties": false
}
