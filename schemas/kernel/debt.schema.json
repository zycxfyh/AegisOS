{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/debt.schema.json",
  "title": "Ordivon Debt",
  "type": "object",
  "required": [
    "debtId",
    "debtType",
    "severity",
    "owner",
    "dueAt",
    "blockingScope",
    "introducedByReceipt",
    "rootCauseCode",
    "rootCauseHypothesis",
    "state"
  ],
  "properties": {
    "debtId": {"type": "string", "minLength": 1},
    "debtType": {"type": "string", "minLength": 1},
    "severity": {"type": "string", "enum": ["info", "low", "medium", "high", "critical"]},
    "owner": {"type": "string", "minLength": 1},
    "dueAt": {"type": "string", "format": "date-time"},
    "blockingScope": {"type": "string", "minLength": 1},
    "introducedByReceipt": {"type": "string", "minLength": 1},
    "rootCauseCode": {"type": "string", "minLength": 1},
    "rootCauseHypothesis": {"type": "string", "minLength": 1},
    "verificationReceipt": {"type": "string"},
    "state": {"type": "string", "enum": ["Open", "Triage", "Planned", "Mitigated", "Verified", "Closed", "Waived"]}
  },
  "additionalProperties": false
}
