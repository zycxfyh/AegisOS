{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/evidence-relation.schema.json",
  "title": "Ordivon Evidence Relation",
  "type": "object",
  "required": ["relationId", "fromEvidenceRef", "toRef", "relation"],
  "properties": {
    "relationId": {"type": "string", "minLength": 1},
    "fromEvidenceRef": {"type": "string", "minLength": 1},
    "toRef": {"type": "string", "minLength": 1},
    "relation": {
      "type": "string",
      "enum": [
        "supports",
        "contradicts",
        "qualifies",
        "narrowsScope",
        "supersedes",
        "revokes",
        "derivesFrom",
        "observes",
        "attests",
        "duplicates",
        "requiresReview"
      ]
    }
  },
  "additionalProperties": false
}
