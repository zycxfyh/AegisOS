{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/closure.schema.json",
  "title": "Ordivon Closure",
  "type": "object",
  "required": [
    "closureId",
    "targetRef",
    "closureReason",
    "verificationReceipt",
    "reopenConditions"
  ],
  "properties": {
    "closureId": {"type": "string", "minLength": 1},
    "targetRef": {"type": "string", "minLength": 1},
    "closureReason": {"type": "string", "minLength": 1},
    "verificationReceipt": {"type": "string", "minLength": 1},
    "reopenConditions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    }
  },
  "additionalProperties": false
}
