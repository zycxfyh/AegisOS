{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/action-spec.schema.json",
  "title": "Ordivon Action Spec",
  "type": "object",
  "required": ["actionClass", "targetRef", "cardinality", "orderConstraint", "approvalMode", "successPredicate"],
  "properties": {
    "actionClass": {
      "type": "string",
      "enum": [
        "READ_RESOURCE",
        "CALL_TOOL_READONLY",
        "CALL_TOOL_MUTATING",
        "SEND_MESSAGE",
        "UPDATE_RECORD",
        "DELETE_RECORD",
        "EXECUTE_CODE",
        "REQUEST_APPROVAL",
        "APPLY_APPROVAL",
        "STATE_TRANSITION"
      ]
    },
    "targetRef": {"type": "string", "minLength": 1},
    "cardinality": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": {"type": "integer", "minimum": 0},
        "max": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "orderConstraint": {"type": "string", "enum": ["none", "declared_order"]},
    "approvalMode": {"type": "string", "enum": ["none", "human", "policy", "break_glass"]},
    "successPredicate": {"type": "string", "minLength": 1},
    "authorityRefs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "idempotencyKey": {"type": "string", "minLength": 1},
    "expectedPayloadHash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
