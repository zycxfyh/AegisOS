{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/review-decision.schema.json",
  "title": "Ordivon Review Decision",
  "type": "object",
  "required": [
    "decisionId",
    "action",
    "targetRef",
    "reviewer",
    "authorityRef",
    "createdAt"
  ],
  "properties": {
    "decisionId": {"type": "string", "minLength": 1},
    "action": {
      "type": "string",
      "enum": [
        "TriageDebt",
        "WaiveDebt",
        "SuppressDebt",
        "CloseDebt",
        "PromoteCandidatePolicy"
      ]
    },
    "targetRef": {"type": "string", "minLength": 1},
    "reviewer": {"type": "string", "minLength": 1},
    "authorityRef": {"type": "string", "minLength": 1},
    "createdAt": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
