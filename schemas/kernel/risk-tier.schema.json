{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/risk-tier.schema.json",
  "title": "Ordivon Risk Tier",
  "type": "object",
  "required": [
    "riskTier",
    "requiredAuthority",
    "receiptStrength",
    "traceRetention",
    "approvalQuorum",
    "rollbackRequirement",
    "humanReview",
    "redTeamCoverage"
  ],
  "properties": {
    "riskTier": {"type": "string", "enum": ["R0", "R1", "R2", "R3", "R4", "R5"]},
    "requiredAuthority": {"type": "string", "minLength": 1},
    "receiptStrength": {"type": "string", "minLength": 1},
    "traceRetention": {"type": "string", "minLength": 1},
    "approvalQuorum": {"type": "string", "minLength": 1},
    "rollbackRequirement": {"type": "string", "minLength": 1},
    "humanReview": {"type": "string", "minLength": 1},
    "redTeamCoverage": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
