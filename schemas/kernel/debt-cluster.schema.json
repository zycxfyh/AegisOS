{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/debt-cluster.schema.json",
  "title": "Ordivon Debt Cluster",
  "type": "object",
  "required": [
    "clusterId",
    "fingerprint",
    "debtRefs",
    "recurrenceCount",
    "severityCeiling"
  ],
  "properties": {
    "clusterId": {"type": "string", "minLength": 1},
    "fingerprint": {"type": "string", "minLength": 1},
    "debtRefs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "recurrenceCount": {"type": "integer", "minimum": 1},
    "severityCeiling": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "candidatePolicyRef": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
