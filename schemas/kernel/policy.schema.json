{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/policy.schema.json",
  "title": "Ordivon Policy",
  "type": "object",
  "required": [
    "policyId",
    "candidatePolicyId",
    "policyHash",
    "scope",
    "status"
  ],
  "properties": {
    "policyId": {"type": "string", "minLength": 1},
    "candidatePolicyId": {"type": "string", "minLength": 1},
    "policyHash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "scope": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["Shadow", "LimitedRollout", "Deprecated", "Retired"]
    }
  },
  "additionalProperties": false
}
