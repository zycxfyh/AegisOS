{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/observed-event.schema.json",
  "title": "Ordivon Observed Event",
  "description": "Facts observed by trusted runtime, adapter, or external attestor. AI_WRITTEN payloads are never valid ObservedEvent sources.",
  "type": "object",
  "required": [
    "eventId",
    "traceId",
    "source",
    "sourceIdentity",
    "observedSequence",
    "eventType",
    "actionClass",
    "targetRef",
    "timestamp",
    "payloadHash",
    "prevEventHash",
    "origin",
    "status",
    "authorityRef",
    "idempotencyKey"
  ],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "traceId": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "sourceIdentity": {"type": "string", "minLength": 1},
    "observedSequence": {"type": "integer", "minimum": 1},
    "eventType": {"type": "string", "minLength": 1},
    "actionClass": {
      "type": "string",
      "enum": [
        "READ_RESOURCE",
        "CALL_TOOL_READONLY",
        "CALL_TOOL_MUTATING",
        "SEND_MESSAGE",
        "UPDATE_RECORD",
        "DELETE_RECORD",
        "EXECUTE_CODE",
        "REQUEST_APPROVAL",
        "APPLY_APPROVAL",
        "STATE_TRANSITION"
      ]
    },
    "targetRef": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "payloadHash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "prevEventHash": {"type": "string", "minLength": 8},
    "origin": {"type": "string", "enum": ["SYSTEM_OBSERVED", "EXTERNAL_ATTESTED"]},
    "status": {"type": "string", "enum": ["Acked", "Observed", "Applied", "Succeeded", "Partial", "Unknown", "Failed"]},
    "authorityRef": {"type": "string", "minLength": 1},
    "idempotencyKey": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
