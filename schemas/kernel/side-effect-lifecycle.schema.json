{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/side-effect-lifecycle.schema.json",
  "title": "Ordivon Side Effect Lifecycle",
  "type": "object",
  "required": ["actionClass", "targetRef", "status", "idempotencyKey"],
  "properties": {
    "actionClass": {"type": "string", "minLength": 1},
    "targetRef": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": [
        "Requested",
        "Authorized",
        "Dispatched",
        "Acked",
        "Observed",
        "Applied",
        "Succeeded",
        "Partial",
        "Unknown",
        "Failed",
        "Compensating",
        "Compensated",
        "Irreversible"
      ]
    },
    "idempotencyKey": {"type": "string", "minLength": 1},
    "observedEventRef": {"type": "string"},
    "compensationRef": {"type": "string"}
  },
  "additionalProperties": false
}
