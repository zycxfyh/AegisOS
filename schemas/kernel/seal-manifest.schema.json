{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/seal-manifest.schema.json",
  "title": "Ordivon Seal Manifest",
  "type": "object",
  "required": ["segmentId", "firstEventSeq", "lastEventSeq", "eventCount", "rootDigest", "sealedAt"],
  "properties": {
    "segmentId": {"type": "string", "minLength": 1},
    "firstEventSeq": {"type": "integer", "minimum": 1},
    "lastEventSeq": {"type": "integer", "minimum": 1},
    "eventCount": {"type": "integer", "minimum": 1},
    "rootDigest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "previousSealRef": {"type": ["string", "null"]},
    "sealedAt": {"type": "string", "format": "date-time"},
    "signatureRefs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  },
  "additionalProperties": false
}
