{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/kernel/break-glass.schema.json",
  "title": "Ordivon Break-glass Authority",
  "type": "object",
  "required": ["breakGlassId", "reason", "approvers", "expiresAt", "openedDebtRef", "nonOverrideableDeniesChecked"],
  "properties": {
    "breakGlassId": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1},
    "approvers": {"type": "array", "items": {"type": "string"}, "minItems": 2, "uniqueItems": true},
    "expiresAt": {"type": "string", "format": "date-time"},
    "openedDebtRef": {"type": "string", "minLength": 1},
    "nonOverrideableDeniesChecked": {"type": "boolean", "const": true}
  },
  "additionalProperties": false
}
