{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/governance/observed-action.schema.json",
  "title": "AOS Observed Action",
  "description": "Post-action ObservedEvent object derived from git/filesystem/registry observations, not AI self-report.",
  "type": "object",
  "required": [
    "schema_version",
    "object_id",
    "object_kind",
    "origin",
    "created_at",
    "created_by",
    "provenance",
    "state",
    "event_id",
    "prev_event_hash",
    "event_hash",
    "source_identity",
    "observed_sequence",
    "source_declaration_ref",
    "observation_sources",
    "git_base_ref",
    "git_head_ref",
    "observed_files_added",
    "observed_files_modified",
    "observed_files_deleted",
    "observed_receipts",
    "observed_registry_entries",
    "unknown_observations",
    "preexisting_dirty_overlap"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^aos-observed-action-v[0-9]+\\.[0-9]+$"
    },
    "object_id": {
      "type": "string",
      "pattern": "^aos:actions:ObservedAction:[a-z0-9_.-]+$"
    },
    "object_kind": {
      "type": "string",
      "enum": ["ObservedAction"]
    },
    "origin": {
      "type": "string",
      "const": "SYSTEM_OBSERVED"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "object",
      "required": ["input_refs", "collector", "digest"],
      "properties": {
        "input_refs": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "collector": {"type": "string", "minLength": 1},
        "digest": {"type": "string", "minLength": 8},
        "signature_refs": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "state": {
      "type": "string",
      "enum": ["OBSERVED"]
    },
    "event_id": {
      "type": "string",
      "pattern": "^aos:event:ObservedAction:[a-z0-9_.-]+$"
    },
    "prev_event_hash": {
      "type": "string",
      "minLength": 8
    },
    "event_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_identity": {
      "type": "string",
      "minLength": 1
    },
    "observed_sequence": {
      "type": "integer",
      "minimum": 1
    },
    "source_declaration_ref": {"type": "string", "minLength": 1},
    "observation_sources": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "git_base_ref": {"type": "string"},
    "git_head_ref": {"type": "string"},
    "observed_files_added": {
      "type": "array",
      "items": {"type": "string"}
    },
    "observed_files_modified": {
      "type": "array",
      "items": {"type": "string"}
    },
    "observed_files_deleted": {
      "type": "array",
      "items": {"type": "string"}
    },
    "observed_receipts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "observed_registry_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "doc_id": {"type": "string"},
          "path": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "observed_debt_transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "debt_id": {"type": "string"},
          "from_status": {"type": "string"},
          "to_status": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "unknown_observations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "preexisting_dirty_overlap": {
      "type": "array",
      "items": {"type": "string"}
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "declaration_hash": {
      "type": "string",
      "minLength": 8
    }
  },
  "additionalProperties": false
}
