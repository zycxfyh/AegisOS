{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/governance/candidate-rule.schema.json",
  "title": "AOS CandidateRule Record Object",
  "description": "Declarative CandidateRule submission. Proposed from lessons, validated in shadow, red-teamed before Policy activation.",
  "type": "object",
  "required": ["object_id", "object_kind", "rule_id", "source_lesson_ref", "rule_body", "proposed_enforcement", "not_claimed"],
  "properties": {
    "object_id": {"type": "string", "pattern": "^aos:rules:CandidateRuleRecord:[a-z0-9_.-]+$"},
    "object_kind": {"type": "string", "enum": ["CandidateRuleRecord"]},
    "rule_id": {"type": "string"},
    "source_lesson_ref": {"type": "string", "description": "Reference to lesson in lesson-ledger.jsonl"},
    "rule_body": {"type": "string", "minLength": 1, "description": "The rule statement"},
    "proposed_enforcement": {"type": "string", "enum": ["advisory", "shadow", "blocking"], "description": "Proposed enforcement level. Must be shadow or advisory initially."},
    "shadow_evaluation_refs": {"type": "array", "items": {"type": "string"}},
    "not_claimed": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  }
}
