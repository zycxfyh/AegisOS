{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/governance/debt-transition.schema.json",
  "title": "AOS Debt Transition Object",
  "description": "Declarative debt lifecycle transition. Submitted as an AOS object to change a debt's status. The system validates evidence and enforces transition rules.",
  "type": "object",
  "required": ["object_id", "object_kind", "debt_id", "from_status", "to_status", "evidence_refs", "reason", "not_claimed"],
  "properties": {
    "object_id": {"type": "string", "pattern": "^aos:debts:DebtTransition:[a-z0-9_.-]+$"},
    "object_kind": {"type": "string", "enum": ["DebtTransition"]},
    "debt_id": {"type": "string", "description": "The debt being transitioned"},
    "from_status": {"type": "string", "enum": ["OPEN", "RENEWED", "CLOSED"]},
    "to_status": {"type": "string", "enum": ["OPEN", "RENEWED", "CLOSED", "SEVERITY_UPGRADED", "SEVERITY_DOWNGRADED"]},
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "description": "Evidence references supporting this transition. Required for CLOSED."
    },
    "reason": {"type": "string", "minLength": 1},
    "severity": {"type": "string", "enum": ["low", "medium", "high", "critical", "blocking"]},
    "review_required": {"type": "boolean", "default": true},
    "not_claimed": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    }
  }
}
