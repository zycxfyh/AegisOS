{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/governance/ai-action-declaration.schema.json",
  "title": "AOS AI Action Declaration",
  "description": "Declarative pre-action object for AI work. It is the AOS Obligation object: not authorization, correctness proof, or scope expansion permission.",
  "type": "object",
  "required": [
    "schema_version",
    "object_id",
    "object_kind",
    "origin",
    "created_at",
    "created_by",
    "provenance",
    "state",
    "actor",
    "declared_action",
    "action_class",
    "action_spec",
    "declared_scope",
    "not_allowed",
    "expected_outputs",
    "not_claimed"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^aos-action-declaration-v[0-9]+\\.[0-9]+$"
    },
    "object_id": {
      "type": "string",
      "pattern": "^aos:actions:AIActionDeclaration:[a-z0-9_.-]+$"
    },
    "object_kind": {
      "type": "string",
      "enum": ["AIActionDeclaration"]
    },
    "origin": {
      "type": "string",
      "enum": ["AI_WRITTEN", "HUMAN_WRITTEN", "SYSTEM_DERIVED"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "object",
      "required": ["input_refs", "collector", "digest"],
      "properties": {
        "input_refs": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "collector": {"type": "string", "minLength": 1},
        "digest": {"type": "string", "minLength": 8},
        "signature_refs": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "state": {
      "type": "string",
      "enum": ["DECLARED"]
    },
    "actor": {
      "type": "object",
      "required": ["actor_type", "actor_id"],
      "properties": {
        "actor_type": {
          "type": "string",
          "enum": ["ai_agent", "human", "system_tool", "unknown"]
        },
        "actor_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "declared_action": {
      "type": "string",
      "minLength": 1
    },
    "action_class": {
      "type": "string",
      "enum": [
        "READ_RESOURCE",
        "CALL_TOOL_READONLY",
        "CALL_TOOL_MUTATING",
        "SEND_MESSAGE",
        "STATE_TRANSITION"
      ]
    },
    "action_spec": {
      "type": "object",
      "required": ["target", "cardinality", "order_constraint", "approval_mode", "success_predicate"],
      "properties": {
        "target": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1,
          "uniqueItems": true
        },
        "cardinality": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": {"type": "integer", "minimum": 0},
            "max": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": false
        },
        "order_constraint": {
          "type": "string",
          "enum": ["none", "declared_order"]
        },
        "approval_mode": {
          "type": "string",
          "enum": ["none", "manual", "policy_token"]
        },
        "success_predicate": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "declared_scope": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "not_allowed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["change_ci", "close_debt", "modify_policy", "claim_authorization", "delete_files"]
      },
      "uniqueItems": true
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["receipt", "registry_entry", "candidate_rule_file", "conformance_audit_receipt"]
      },
      "uniqueItems": true
    },
    "not_claimed": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 3
    }
  },
  "additionalProperties": false
}
