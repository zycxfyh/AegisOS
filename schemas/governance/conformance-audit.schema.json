{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/governance/conformance-audit.schema.json",
  "title": "AOS Declaration-Action Conformance Audit",
  "description": "Machine-bounded Comparator/Receipt object between an AIActionDeclaration and ObservedAction. It does not judge quality, intent, evidence sufficiency, or authorization.",
  "type": "object",
  "required": [
    "schema_version",
    "object_id",
    "object_kind",
    "origin",
    "created_at",
    "created_by",
    "provenance",
    "state",
    "declaration_ref",
    "observed_action_ref",
    "verdict",
    "result",
    "findings",
    "unknowns",
    "review_required",
    "not_judged"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^aos-conformance-audit-v[0-9]+\\.[0-9]+$"
    },
    "object_id": {
      "type": "string",
      "pattern": "^aos:actions:ConformanceAudit:[a-z0-9_.-]+$"
    },
    "object_kind": {
      "type": "string",
      "enum": ["ConformanceAudit"]
    },
    "origin": {
      "type": "string",
      "const": "SYSTEM_DERIVED"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "object",
      "required": ["input_refs", "collector", "digest"],
      "properties": {
        "input_refs": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "collector": {"type": "string", "minLength": 1},
        "digest": {"type": "string", "minLength": 8},
        "signature_refs": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "state": {
      "type": "string",
      "enum": ["ISSUED"]
    },
    "declaration_ref": {"type": "string", "minLength": 1},
    "observed_action_ref": {"type": "string", "minLength": 1},
    "verdict": {
      "type": "string",
      "enum": [
        "ExactMatch",
        "Under",
        "Over",
        "Mis",
        "Unverifiable",
        "DeclarationInvalid",
        "SystemError"
      ]
    },
    "result": {
      "type": "string",
      "enum": ["MATCH", "MISMATCH", "UNKNOWN", "REVIEW_REQUIRED"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_type", "description"],
        "properties": {
          "finding_type": {
            "type": "string",
            "enum": [
              "ACTION_MISMATCH",
              "SCOPE_MISMATCH",
              "FORBIDDEN_ACTION",
              "EXPECTED_OUTPUT_MISSING",
              "DECLARATION_INVALID",
              "SYSTEM_ERROR",
              "UNVERIFIABLE"
            ]
          },
          "description": {"type": "string"},
          "declared": {},
          "observed": {},
          "affected_paths": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      }
    },
    "unknowns": {
      "type": "array",
      "items": {"type": "string"}
    },
    "review_required": {
      "type": "array",
      "items": {"type": "string"}
    },
    "not_judged": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "audited_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
