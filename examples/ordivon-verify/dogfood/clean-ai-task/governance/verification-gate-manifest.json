{
  "manifest_id": "dogfood-clean-v1",
  "profile": "standard",
  "version": "0.1",
  "gate_count": 2,
  "gates": [
    {
      "gate_id": "unit_tests",
      "display_name": "Unit tests",
      "hardness": "hard",
      "command": "uv run python -m pytest tests/unit/test_example_validator.py -q",
      "purpose": "Verify behavior claimed by the AI coding task."
    },
    {
      "gate_id": "format_check",
      "display_name": "Format check",
      "hardness": "hard",
      "command": "uv run ruff format --check src tests",
      "purpose": "Verify formatting did not drift."
    }
  ]
}
