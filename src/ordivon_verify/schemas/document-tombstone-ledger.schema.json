{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/document-tombstone-ledger.schema.json",
  "title": "Document Tombstone Ledger Entry",
  "description": "Schema for tracking tombstoned documents. Prototype artifact.",
  "type": "object",
  "required": ["tombstone_id", "doc_id", "path", "status", "reason", "tombstoned_at"],
  "properties": {
    "tombstone_id": {"type": "string"},
    "doc_id": {"type": "string"},
    "path": {"type": "string"},
    "status": {"type": "string", "enum": ["tombstoned","pending_tombstone"]},
    "reason": {"type": "string"},
    "tombstoned_at": {"type": "string", "format": "date"},
    "owner": {"type": "string"},
    "successor_path": {"type": "string"},
    "review_date": {"type": "string", "format": "date"},
    "notes": {"type": "string"}
  }
}
