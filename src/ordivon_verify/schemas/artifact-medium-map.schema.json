{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/artifact-medium-map.schema.json",
  "title": "Artifact Medium Map Entry",
  "description": "Schema for mapping media formats to their authority defaults. Prototype artifact.",
  "type": "object",
  "required": ["medium_id", "extension_or_format", "source_or_generated", "default_authority_tier", "current_truth_allowed_default"],
  "properties": {
    "medium_id": {"type": "string"},
    "extension_or_format": {"type": "string"},
    "purpose": {"type": "string"},
    "source_or_generated": {"type": "string", "enum": ["source","generated"]},
    "default_authority_tier": {"type": "string"},
    "current_truth_allowed_default": {"type": "boolean"},
    "lifecycle_default": {"type": "string"},
    "owner_required": {"type": "boolean"},
    "allowed_uses": {"type": "array", "items": {"type": "string"}},
    "prohibited_uses": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "string"}
  }
}
