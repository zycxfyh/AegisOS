{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/ai-context-map.schema.json",
  "title": "AI Context Map",
  "description": "Machine-readable snapshot of current Ordivon context for AI onboarding. Prototype artifact.",
  "type": "object",
  "required": ["version", "last_verified", "current_truth_docs", "no_go_docs"],
  "properties": {
    "version": {"type": "string"},
    "generated_or_manual": {"type": "string"},
    "current_phase": {"type": "string"},
    "registry_index_command": {"type": "string"},
    "last_verified": {"type": "string", "format": "date"},
    "owner": {"type": "string"},
    "archive_warning": {"type": "string"},
    "generated_view_warning": {"type": "string"},
    "current_truth_docs": {"type": "array", "items": {"type": "string"}},
    "root_context_docs": {"type": "array", "items": {"type": "string"}},
    "active_pack_docs": {"type": "array", "items": {"type": "string"}},
    "no_go_docs": {"type": "array", "items": {"type": "string"}},
    "receipt_contract_docs": {"type": "array", "items": {"type": "string"}},
    "onboarding_reading_order": {"type": "array", "items": {"type": "string"}}
  }
}
