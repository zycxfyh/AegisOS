{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/knowledge-map.schema.json",
  "title": "Knowledge Map",
  "description": "Machine-readable navigation graph of Ordivon governed objects. Prototype artifact.",
  "type": "object",
  "required": ["version", "last_verified", "current_truth_nodes"],
  "properties": {
    "version": {"type": "string"},
    "generated_or_manual": {"type": "string"},
    "current_truth_nodes": {"type": "array", "items": {"type": "object"}},
    "active_phase_nodes": {"type": "array", "items": {"type": "object"}},
    "pack_nodes": {"type": "array", "items": {"type": "object"}},
    "registry_nodes": {"type": "array", "items": {"type": "object"}},
    "stage_summit_nodes": {"type": "array", "items": {"type": "object"}},
    "receipt_nodes": {"type": "array", "items": {"type": "object"}},
    "archive_nodes": {"type": "array", "items": {"type": "object"}},
    "generated_view_nodes": {"type": "array", "items": {"type": "object"}},
    "edges": {"type": "array", "items": {"type": "object"}},
    "owner": {"type": "string"},
    "last_verified": {"type": "string"}
  }
}
