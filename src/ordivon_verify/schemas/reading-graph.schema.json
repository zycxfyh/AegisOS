{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/reading-graph.schema.json",
  "title": "AI Reading Graph",
  "description": "Ordered entry points for AI onboarding. Prototype artifact.",
  "type": "object",
  "required": ["version", "start_nodes", "required_nodes"],
  "properties": {
    "version": {"type": "string"},
    "start_nodes": {"type": "array", "items": {"type": "string"}},
    "required_nodes": {"type": "array", "items": {"type": "string"}},
    "optional_nodes": {"type": "array", "items": {"type": "string"}},
    "forbidden_as_current_truth_nodes": {"type": "array", "items": {"type": "string"}},
    "archive_warning_nodes": {"type": "array", "items": {"type": "string"}},
    "generated_view_nodes": {"type": "array", "items": {"type": "string"}},
    "max_initial_reading_set": {"type": "integer"},
    "expansion_rules": {"type": "string"}
  }
}
