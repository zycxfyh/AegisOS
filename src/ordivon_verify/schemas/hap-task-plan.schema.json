{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/hap/task-plan-v0",
  "title": "HAP HarnessTaskPlan v0",
  "description": "Pre-action plan object. TaskPlan is not execution permission.",
  "type": "object",
  "_maturity": "prototype",
  "_disclaimer": "HAP v0 prototype schema. TaskPlan describes intent and boundaries only. It does not authorize execution.",
  "required": [
    "schema_version", "object_type", "plan_id",
    "capability_class", "risk_level", "authority_impact",
    "planned_status", "allowed_files", "forbidden_files",
    "protected_paths", "no_action_authorization_statement"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "object_type": {"type": "string", "const": "HarnessTaskPlan"},
    "plan_id": {"type": "string"},
    "related_task_request_id": {"type": "string"},
    "related_adapter_manifest_id": {"type": "string"},
    "capability_class": {"type": "string", "enum": ["C0","C1","C2","C3","C4","C5"]},
    "risk_level": {"type": "string", "enum": ["AP-R0","AP-R1","AP-R2","AP-R3","AP-R4","AP-R5"]},
    "authority_impact": {"type": "string", "enum": ["AI-0","AI-1","AI-2","AI-3","AI-4","AI-5","AI-6"]},
    "planned_status": {"type": "string", "enum": ["PLAN_ONLY","REVIEW_REQUIRED","BLOCKED","NO_GO","READY_WITHOUT_AUTHORIZATION"]},
    "allowed_files": {"type": "array", "items": {"type": "string"}},
    "forbidden_files": {"type": "array", "items": {"type": "string"}},
    "protected_paths": {"type": "array", "items": {"type": "string"}},
    "planned_operations": {"type": "array", "items": {"type": "string"}},
    "shell_commands_planned": {"type": "array", "items": {"type": "string"}},
    "external_side_effects_planned": {"type": "array", "items": {"type": "string"}},
    "credential_access_planned": {"type": "boolean", "default": false},
    "mcp_or_browser_use_planned": {"type": "boolean", "default": false},
    "evidence_plan": {"type": "array", "items": {"type": "string"}},
    "verification_plan": {"type": "array", "items": {"type": "string"}},
    "rollback_plan": {"type": "string"},
    "boundary_statement": {"type": "string"},
    "no_action_authorization_statement": {"type": "string"},
    "closure_criteria": {"type": "array", "items": {"type": "string"}},
    "known_debt_references": {"type": "array", "items": {"type": "string"}},
    "candidate_rule_references": {"type": "array", "items": {"type": "string"}},
    "next_review_required": {"type": "boolean", "default": true}
  },
  "additionalProperties": false
}
