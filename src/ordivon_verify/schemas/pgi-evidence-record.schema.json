{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.local/schemas/pgi-evidence-record.schema.json",
  "title": "PGI Evidence Record",
  "description": "A local evidence record for philosophical governance. Evidence is not authority and does not authorize action.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object_type",
    "schema_version",
    "evidence_id",
    "evidence_kind",
    "source",
    "observed_at",
    "actor",
    "scope",
    "reproducibility",
    "freshness",
    "confidence",
    "supports_claims",
    "limitations",
    "authority_boundary"
  ],
  "properties": {
    "object_type": {
      "const": "PGIEvidenceRecord"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.\\d+$"
    },
    "evidence_id": {
      "type": "string",
      "minLength": 3
    },
    "evidence_kind": {
      "type": "string",
      "enum": [
        "file_read",
        "command_output",
        "test_result",
        "human_review",
        "receipt",
        "external_source",
        "observation",
        "absence",
        "contradiction"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string"},
        "command": {"type": "string"},
        "reference": {"type": "string"},
        "description": {"type": "string"}
      }
    },
    "observed_at": {
      "type": "string",
      "description": "Exact timestamp or date when evidence was observed."
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "reproducibility": {
      "type": "string",
      "enum": ["reproducible", "contextual", "non_reproducible", "unknown"]
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["CURRENT", "STALE", "DEGRADED", "MISSING"]
        },
        "last_verified": {"type": ["string", "null"]},
        "stale_after_days": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "supports_claims": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "authority_boundary": {
      "type": "string",
      "description": "Must explicitly state that evidence does not authorize action."
    }
  }
}
