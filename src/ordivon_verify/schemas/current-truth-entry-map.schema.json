{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/current-truth-entry-map.schema.json",
  "title": "Current Truth Entry Map Record",
  "description": "Schema for a current truth entry — a document explicitly authorized to carry current truth status. Prototype artifact.",
  "type": "object",
  "required": ["entry_id", "doc_id", "path", "authority_type", "authority_tier", "current_truth_allowed"],
  "properties": {
    "entry_id": {"type": "string"},
    "doc_id": {"type": "string"},
    "path": {"type": "string"},
    "authority_type": {"type": "string", "enum": ["source_of_truth","current_status","supporting_evidence"]},
    "authority_tier": {"type": "string", "enum": ["T0_SOURCE_OF_TRUTH","T1_CURRENT_STATUS"]},
    "current_truth_allowed": {"type": "boolean"},
    "owner": {"type": "string"},
    "last_verified": {"type": "string"},
    "review_date": {"type": "string"},
    "source_registry": {"type": "string"},
    "successor_or_superseded_by": {"type": "string"},
    "notes": {"type": "string"}
  }
}
