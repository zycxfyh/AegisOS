{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/phase-closure-ledger.schema.json",
  "title": "Phase Closure Ledger Entry",
  "description": "Schema for tracking phase closures in Ordivon. Prototype artifact.",
  "type": "object",
  "required": ["phase_id", "status", "receipt_path", "closed_at"],
  "properties": {
    "phase_id": {"type": "string", "description": "Phase identifier (e.g. DGP-2, RG-10)."},
    "status": {"type": "string", "enum": ["CLOSED","PARTIAL","BLOCKED","CANDIDATE_CLOSED"]},
    "receipt_path": {"type": "string", "description": "Path to phase closure receipt."},
    "summit_path": {"type": "string", "description": "Path to stage summit if this phase is part of one."},
    "authority_impact": {"type": "string"},
    "authorization_impact": {"type": "string", "description": "Must state 'none' unless authorization changed."},
    "validation_summary": {"type": "string", "description": "Summary of validation command output."},
    "known_debts": {"type": "string"},
    "closed_at": {"type": "string", "format": "date"},
    "owner": {"type": "string"},
    "review_date": {"type": "string", "format": "date"}
  }
}
