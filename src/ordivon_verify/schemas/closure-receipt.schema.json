{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/closure-receipt.schema.json",
  "title": "ClosureReceipt",
  "description": "Ordivon Control Plane — machine-verifiable stage receipt. Every governance stage produces one of these. It is the provenance artifact that connects desired state (StageManifest) to actual state (RepoSnapshot) through verification evidence.",
  "type": "object",
  "required": ["stage_id", "risk_class", "authority_impact", "timestamp", "verification_results", "boundary_violations", "closure_predicates", "overall"],
  "properties": {
    "stage_id": {
      "type": "string",
      "description": "Unique stage identifier"
    },
    "risk_class": {
      "type": "string",
      "enum": ["AP-R0", "AP-R1", "AP-R2", "AP-R3"]
    },
    "authority_impact": {
      "type": "string",
      "enum": ["AI-0", "AI-1", "AI-2", "AI-3"]
    },
    "task_type": {
      "type": "string"
    },
    "template_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "head_commit": {
      "type": "string",
      "description": "Git commit at time of closure"
    },
    "files_changed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "verification_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "passed", "exit_code"],
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "command": {"type": "string"},
          "passed": {"type": "boolean"},
          "exit_code": {"type": "integer"},
          "output_hash": {"type": "string", "description": "SHA-256 of verification output for tamper detection"},
          "duration_ms": {"type": "integer"}
        }
      }
    },
    "boundary_violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "pattern", "severity"],
        "properties": {
          "file": {"type": "string"},
          "pattern": {"type": "string"},
          "severity": {"type": "string", "enum": ["BLOCKED", "DEGRADED", "ADVISORY"]},
          "category": {"type": "string", "enum": ["boundary", "authority", "evidence", "closure"]}
        }
      }
    },
    "evidence_produced": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": {"type": "string", "enum": ["git_diff", "command_output", "checker_result", "file_change_list", "registry_diff"]},
          "path": {"type": "string"},
          "hash": {"type": "string"}
        }
      }
    },
    "closure_predicates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "satisfied"],
        "properties": {
          "id": {"type": "string"},
          "satisfied": {"type": "boolean"},
          "evidence_ref": {"type": "string"}
        }
      }
    },
    "authorization": {
      "type": "object",
      "properties": {
        "status": {"type": "string", "enum": ["not_requested", "requested", "approved", "rejected", "expired"]},
        "approver": {"type": "string"},
        "approved_at": {"type": "string", "format": "date-time"},
        "rationale": {"type": "string"}
      }
    },
    "overall": {
      "type": "string",
      "enum": ["READY", "DEGRADED", "BLOCKED"]
    },
    "notes": {
      "type": "string",
      "description": "Human-readable notes for the receipt"
    }
  }
}
