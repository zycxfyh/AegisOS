{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/document-lifecycle-ledger.schema.json",
  "title": "Document Lifecycle Ledger Entry",
  "description": "Schema for tracking document lifecycle state transitions in the Registry Control Plane. Prototype artifact.",
  "type": "object",
  "required": ["doc_id", "path", "lifecycle_state", "authority_tier", "current_truth_allowed", "owner"],
  "properties": {
    "doc_id": {"type": "string"},
    "path": {"type": "string"},
    "lifecycle_state": {
      "type": "string",
      "enum": ["draft","candidate","active","stable","generated","archived","deprecated","tombstoned","legacy_inactive","out_of_scope"]
    },
    "authority_tier": {
      "type": "string",
      "enum": ["T0_SOURCE_OF_TRUTH","T1_CURRENT_STATUS","T2_SUPPORTING_EVIDENCE","T3_CANDIDATE_PROPOSAL","T4_ARCHIVE_HISTORICAL","T5_DEPRECATED_TOMBSTONED","T6_OUT_OF_SCOPE"]
    },
    "current_truth_allowed": {"type": "boolean"},
    "owner": {"type": "string"},
    "last_verified": {"type": "string"},
    "review_date": {"type": "string"},
    "supersedes": {"type": "string"},
    "superseded_by": {"type": "string"},
    "tombstone_reason": {"type": "string"},
    "reentry_condition": {"type": "string"},
    "notes": {"type": "string"}
  }
}
