{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/document-supersession-map.schema.json",
  "title": "Document Supersession Map Entry",
  "description": "Schema for tracking document supersession relationships. Prototype artifact.",
  "type": "object",
  "required": ["old_doc_id", "old_path", "new_doc_id", "new_path", "supersession_reason"],
  "properties": {
    "old_doc_id": {"type": "string"},
    "old_path": {"type": "string"},
    "new_doc_id": {"type": "string"},
    "new_path": {"type": "string"},
    "supersession_reason": {"type": "string"},
    "owner": {"type": "string"},
    "effective_date": {"type": "string", "format": "date"},
    "notes": {"type": "string"}
  }
}
